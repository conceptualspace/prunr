<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>net.conceptualspace.prunr</id>

  <name>Prunr</name>
  <summary>Find and remove duplicate files</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      Prunr is a fast and powerful tool for disk cleanup. Use it to analyze disk
      usage, identify duplicate files, and safely reclaim wasted space.
    </p>
    <p>Features:</p>
    <ul>
      <li>Duplicate detection: Fast (hardware-accelerated) duplicate file scanning. Supports previews, filters and auto-selection options to safely and easily cleanup files.</li>
      <li>Analyze disk usage: Interactive treemap and sunburst visualizations show where disk space is going, color-coded by file type.</li>
      <li>Secure and open source: Prunr runs fully locally and no data ever leaves your system.</li>
    </ul>
  </description>

  <launchable type="desktop-id">net.conceptualspace.prunr.desktop</launchable>

  <url type="homepage">https://prunr.conceptualspace.net</url>
  <url type="bugtracker">https://github.com/conceptualspace/prunr/issues</url>

  <developer id="net.conceptualspace">
    <name>conceptualspace</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#e0f0ff</color>
    <color type="primary" scheme_preference="dark">#242424</color>
  </branding>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.2.4" date="2026-04-09">
      <description>
        <p>Flatpak release.</p>
